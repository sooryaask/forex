//@version=5
indicator("AI CFD Movement+Liquidity (5m)", overlay=true, max_lines_count=500)

// Inputs for manual or webhook-steered values
movement = input.float(0.0, "Movement Score", step=0.1)
liquidity = input.float(50.0, "Liquidity Score", minval=0, maxval=100, step=0.1)
show_labels = input.bool(true, "Show Score Labels")

// Map score to colors
movement_color = movement > 10 ? color.green : movement < -10 ? color.red : color.yellow
liq_color = liquidity > 70 ? color.green : liquidity > 40 ? color.yellow : color.red

// Plot horizontal ranges
hline(10, "Movement Bullish", color=color.new(color.green, 70), linestyle=hline.style_dotted)
hline(-10, "Movement Bearish", color=color.new(color.red, 70), linestyle=hline.style_dotted)

plot(movement, "Movement Score", color=movement_color, linewidth=2, style=plot.style_line)
plot(liquidity / 2 - 50, "Liquidity Score" , color=liq_color, linewidth=2, style=plot.style_area)

plotshape(show_labels and movement > 10 and liquidity > 60, title="Strong Long", location=location.abovebar, color=color.lime, style=shape.labelup, text="BUY")
plotshape(show_labels and movement < -10 and liquidity > 60, title="Strong Short", location=location.belowbar, color=color.red, style=shape.labeldown, text="SELL")
plotshape(show_labels and abs(movement) <= 10, title="Neutral", location=location.top, color=color.gray, style=shape.circle, text="NEUTRAL")

bgcolor(movement > 10 and liquidity > 60 ? color.new(color.green, 90) : movement < -10 and liquidity > 60 ? color.new(color.red, 90) : na)

// Guidance text
var label guide = na
if barstate.islast
    label.delete(guide)
    guide := label.new(bar_index, high, "AI movement: " + str.tostring(movement, format.percent) + " | liquidity: " + str.tostring(liquidity, format.percent) + "\nUse 5m TF and real predictions from API.", xloc.bar_index, yloc.price, color=color.new(color.blue, 90), textcolor=color.white, style=label.style_label_left)
