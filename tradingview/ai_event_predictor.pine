// ═══════════════════════════════════════════════════════════════
// AI Event Similarity Predictor (Self-Contained)
// Auto-generated on 2026-03-22 12:16 UTC
// Event DB: 2400 total outcome samples
// ═══════════════════════════════════════════════════════════════

//@version=5
indicator("AI Event Predictor", overlay=true, max_labels_count=50)

// ─── Inputs ───────────────────────────────────────────────────
i_event_type  = input.string("CPI", "Event Type", options=["CPI", "GDP", "RATE", "EMPLOYMENT", "NFP", "PPI", "RETAIL_SALES", "PMI", "TRADE_BALANCE", "HOUSING"])
i_direction   = input.string("Positive", "Surprise Direction", options=["Positive", "Negative"])
i_importance  = input.int(3, "Importance (1-3)", minval=1, maxval=3)
i_window      = input.string("15m", "Prediction Window", options=["5m", "15m", "60m"])
i_show_table  = input.bool(true, "Show Stats Table")
i_show_target = input.bool(true, "Show Target Lines")

// ─── Asset Class Detection ────────────────────────────────────
// 0=forex, 1=stocks, 2=metals, 3=crypto
f_detect_asset() =>
    sym = syminfo.ticker
    base = syminfo.basecurrency
    quote = syminfo.currency
    stype = syminfo.type
    if stype == "crypto"
        3
    else if stype == "forex"
        0
    else if str.contains(sym, "GOLD") or str.contains(sym, "XAUUSD") or str.contains(sym, "GC") or str.contains(sym, "SILVER") or str.contains(sym, "XAGUSD") or str.contains(sym, "SI")
        2
    else if base == "XAU" or base == "XAG" or quote == "XAU" or quote == "XAG"
        2
    else
        1  // stocks / indices / ETFs

asset_class = f_detect_asset()

// ─── Map inputs to array indices ──────────────────────────────
f_event_idx() =>
    if i_event_type == "CPI"
        0
    else if i_event_type == "GDP"
        1
    else if i_event_type == "RATE"
        2
    else if i_event_type == "EMPLOYMENT"
        3
    else if i_event_type == "NFP"
        4
    else if i_event_type == "PPI"
        5
    else if i_event_type == "RETAIL_SALES"
        6
    else if i_event_type == "PMI"
        7
    else if i_event_type == "TRADE_BALANCE"
        8
    else if i_event_type == "HOUSING"
        9
    else
        0

event_idx = f_event_idx()
dir_idx   = i_direction == "Positive" ? 0 : 1

// Flat index = event_idx * 8 + dir_idx * 4 + asset_class
flat_idx = event_idx * 8 + dir_idx * 4 + asset_class

// ─── Historical Reaction Data ─────────────────────────────────
// 80 entries: 10 event types × 2 directions × 4 asset classes

