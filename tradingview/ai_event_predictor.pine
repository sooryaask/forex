// ─── Prediction Logic ─────────────────────────────────────────
pred_5m  = f_get_avg5m(flat_idx)
pred_15m = f_get_avg15m(flat_idx)
pred_60m = f_get_avg60m(flat_idx)
std_dev  = f_get_dev15m(flat_idx)
n_samples = f_get_cnt(flat_idx)

// Select prediction based on chosen window
pred_move = i_window == "5m" ? pred_5m : i_window == "15m" ? pred_15m : pred_60m

// ─── Movement Score & Signal ──────────────────────────────────
// Scale: ±0.5% move → ±50 movement score
movement_score = math.max(math.min(pred_move * 100.0, 100.0), -100.0)

// Confidence based on sample count and importance
sample_conf  = math.min(n_samples / 10.0, 1.0)
imp_conf     = i_importance / 3.0
std_penalty  = std_dev > 0 ? math.max(1.0 - std_dev / 2.0, 0.1) : 0.5
confidence   = sample_conf * 0.4 + imp_conf * 0.2 + std_penalty * 0.4
confidence  := math.min(math.max(confidence, 0.0), 1.0)

// Liquidity estimate: drops during high-importance events
liquidity = 85.0 - i_importance * 8.0 + (confidence - 0.5) * 20.0
liquidity := math.max(math.min(liquidity, 100.0), 20.0)

// Signal generation
is_buy  = movement_score > 12 and liquidity > 55 and confidence > 0.4 and n_samples > 2
is_sell = movement_score < -12 and liquidity > 55 and confidence > 0.4 and n_samples > 2

// ─── Target Price Lines ───────────────────────────────────────
pred_pct     = pred_move / 100.0  // convert from % to decimal
target_price = close * (1.0 + pred_pct)
stop_price   = close * (1.0 - pred_pct * 0.6)

var line target_line = na
var line stop_line   = na
var label target_lbl = na

if barstate.islast and i_show_target and n_samples > 0
    // Clean up old lines
    if not na(target_line)
        line.delete(target_line)
    if not na(stop_line)
        line.delete(stop_line)
    if not na(target_lbl)
        label.delete(target_lbl)

    t_color = pred_move > 0 ? color.green : color.red
    target_line := line.new(bar_index - 10, target_price, bar_index + 10, target_price, color=t_color, width=2, style=line.style_dashed)
    stop_line   := line.new(bar_index - 10, stop_price, bar_index + 10, stop_price, color=color.orange, width=1, style=line.style_dotted)
    target_lbl  := label.new(bar_index + 11, target_price, "Target: " + str.tostring(target_price, format.mintick) + " (" + str.tostring(pred_move, "#.##") + "%)", color=color.new(t_color, 80), textcolor=color.white, style=label.style_label_left)

// ─── Signal Labels ────────────────────────────────────────────
plotshape(is_buy  and barstate.islast, title="BUY",  location=location.belowbar, color=color.lime, style=shape.labelup,   text="BUY",  size=size.normal)
plotshape(is_sell and barstate.islast, title="SELL", location=location.abovebar, color=color.red,  style=shape.labeldown, text="SELL", size=size.normal)

// ─── Background ───────────────────────────────────────────────
bg_color = is_buy ? color.new(color.green, 92) : is_sell ? color.new(color.red, 92) : na
bgcolor(barstate.islast ? bg_color : na)

// ─── Stats Table ──────────────────────────────────────────────
if barstate.islast and i_show_table
    var table t = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80), border_width=1)

    ac_name = asset_class == 0 ? "FOREX" : asset_class == 1 ? "STOCKS" : asset_class == 2 ? "METALS" : "CRYPTO"
    signal_txt = is_buy ? "BUY" : is_sell ? "SELL" : "NEUTRAL"
    signal_clr = is_buy ? color.lime : is_sell ? color.red : color.gray

    table.cell(t, 0, 0, "Event", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 0, i_event_type + " (" + i_direction + ")", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "Asset Class", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 1, ac_name, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "Signal", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 2, signal_txt, text_color=signal_clr, text_size=size.small)
    table.cell(t, 0, 3, "Movement", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(movement_score, "#.#"), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 4, "Confidence", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(confidence * 100, "#.#") + "%", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 5, "Liquidity", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 5, str.tostring(liquidity, "#.#"), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 6, "Avg Move 5m", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 6, str.tostring(pred_5m, "#.####") + "%", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 7, "Avg Move 15m", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 7, str.tostring(pred_15m, "#.####") + "%", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 8, "Avg Move 60m", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 8, str.tostring(pred_60m, "#.####") + "%", text_color=color.white, text_size=size.small)
    table.cell(t, 0, 9, "Sample Count", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 9, str.tostring(n_samples), text_color=color.white, text_size=size.small)

// ─── Alerts ───────────────────────────────────────────────────
alertcondition(is_buy,  title="Event BUY Signal",  message="AI Event Predictor: BUY on {{ticker}} | Movement: " + str.tostring(movement_score) + " | Confidence: " + str.tostring(confidence))
alertcondition(is_sell, title="Event SELL Signal", message="AI Event Predictor: SELL on {{ticker}} | Movement: " + str.tostring(movement_score) + " | Confidence: " + str.tostring(confidence))
